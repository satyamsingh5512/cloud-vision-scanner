{
  "name": "attendscan",
  "version": "1.0.0",
  "description": "QR Code Attendance & Verification System",
  "private": true,
  "scripts": {
    "ports:free": "sh -c 'fuser -k 5000/tcp 5173/tcp 2>/dev/null || true'",
    "dev": "npm run ports:free && concurrently -n \"backend,web\" -c \"cyan,magenta\" \"nodemon\" \"vite\"",
    "dev:backend": "nodemon",
    "dev:web": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "start": "node backend/server.js",
    "lint": "eslint .",
    "prisma:generate": "prisma generate --schema backend/prisma/schema.prisma",
    "postinstall": "prisma generate --schema backend/prisma/schema.prisma"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.5.0",
    "@prisma/client": "^7.5.0",
    "@tailwindcss/vite": "^4.2.1",
    "axios": "^1.13.6",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "csv-parser": "^3.2.0",
    "dotenv": "^16.4.5",
    "express": "^4.18.3",
    "express-rate-limit": "^7.2.0",
    "html5-qrcode": "^2.3.8",
    "jsonwebtoken": "^9.0.2",
    "multer": "^2.1.1",
    "pg": "^8.20.0",
    "prisma": "^7.5.0",
    "qrcode": "^1.5.3",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-router-dom": "^7.13.1",
    "tailwindcss": "^4.2.1",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "concurrently": "^8.2.2",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "nodemon": "^3.1.0",
    "vite": "^7.3.1"
  }
}
